{
  "name": "pz-server-creator",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win",
    "release": "vite build && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:config-roundtrip": "electron tests/configRoundTrip.test.mjs",
    "test:workshop-parser": "node tests/workshopParser.test.mjs",
    "test:server-session": "node tests/serverSessionStore.test.mjs",
    "test:error-report-utils": "node tests/errorReportUtils.test.mjs"
  },
  "build": {
    "appId": "com.knoxhost.app",
    "productName": "KnoxHost",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Vondalo",
        "repo": "KnoxHost_Project_Zomboid_Dedicated_Server"
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.24",
    "ini": "^6.0.0",
    "leaflet": "^1.9.4",
    "luaparse": "^0.3.1",
    "lucide-react": "^0.554.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vite": "^5.2.0",
    "wait-on": "^9.0.3"
  }
}
